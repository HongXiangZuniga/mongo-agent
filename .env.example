# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env (ya está en .gitignore).

# --- HTTP server ---
PORT=8080
API_TOKEN=<api_token>

# --- MongoDB Atlas (usuario dedicado con rol "read", solo lectura) ---
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<your-cluster>.mongodb.net/?retryWrites=false&w=majority
MONGODB_DB_NAME=<db_name>
MONGODB_QUERY_TIMEOUT_SECONDS=10
MONGODB_MAX_RESULT_LIMIT=50
MONGO_SAMPLE_SIZE=5

# --- OpenCode Zen (proveedor de LLM, endpoint OpenAI-compatible) ---
OPENCODE_API_KEY=<opencode_api_key>
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=opencode/gpt-5.5

# --- Bucle agéntico ---
AGENT_MAX_TOOL_ITERATIONS=6
AGENT_REQUEST_TIMEOUT_SECONDS=30

# --- Redis (memoria de conversación por sesión) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_TTL_SECONDS=3600
