# Copia este archivo a .env y completa los valores reales.
# NUNCA commitees el archivo .env (ya está en .gitignore).

# --- HTTP server ---
PORT=8080
API_TOKEN=<api_token>

# --- MongoDB Atlas (usuario dedicado con rol "read", solo lectura) ---
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<your-cluster>.mongodb.net/?retryWrites=false&w=majority
MONGODB_DB_NAME=<db_name>
MONGODB_QUERY_TIMEOUT_SECONDS=10
MONGODB_MAX_RESULT_LIMIT=50
MONGO_SAMPLE_SIZE=5

# --- OpenCode Zen (proveedor de LLM, endpoint OpenAI-compatible) ---
# OPENCODE_MODEL es el <model-id> listado en GET {OPENCODE_BASE_URL}/models,
# SIN prefijo "opencode/". Los modelos con sufijo "-free" no consumen saldo.
OPENCODE_API_KEY=<opencode_api_key>
OPENCODE_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_MODEL=deepseek-v4-flash-free

# --- Bucle agéntico ---
# Iteraciones máximas de tool-calling por pregunta. Si el agente agota las
# iteraciones antes de responder ("tool loop exceeded"), súbela (p. ej. 10).
AGENT_MAX_TOOL_ITERATIONS=6
# Tiempo máximo total por pregunta (incluye llamadas al LLM y a MongoDB).
AGENT_REQUEST_TIMEOUT_SECONDS=30

# --- Redis (memoria de conversación por sesión) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
SESSION_TTL_SECONDS=3600

# --- Interfaz web de chat (htmx) ---
# Nombre de la cookie HttpOnly que autentica la interfaz web (su valor es API_TOKEN).
WEB_AUTH_COOKIE_NAME=web_auth
# Poner a true cuando el despliegue sirva HTTPS (cookie Secure).
WEB_COOKIE_SECURE=false
# Max-Age de la cookie web en segundos (por defecto 7 días).
WEB_SESSION_MAX_AGE_SECONDS=604800
# Longitud máxima del título de pestaña derivado de la primera pregunta.
WEB_SESSION_TITLE_MAX_LENGTH=40
